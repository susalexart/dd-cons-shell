{
  "name": "dd-cons-shell",
  "version": "0.1.0",
  "private": true,
  "description": "Umbrella shell for dd-cons.aroma-cloud.online — better-auth issuer + marketing/pricing chrome for dev-division and consulting-agency.",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=22.12"
  },
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @ddcons/web dev",
    "build": "pnpm -r --filter \"./apps/*\" run build",
    "start": "pnpm --filter @ddcons/web start",
    "typecheck": "tsc -b",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:integration": "vitest run --project integration"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/node": "^22.19.19",
    "tsx": "4.22.4",
    "typescript": "^5.6.3",
    "vitest": "4.1.8"
  }
}
