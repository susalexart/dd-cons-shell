# dd-cons-shell — umbrella Next.js (auth issuer + marketing + pricing).
# Listens on :3000 inside the container. Compose maps host :3000 → container :3000.
FROM node:22-alpine AS base
RUN apk add --no-cache git && corepack enable && corepack prepare pnpm@latest --activate
WORKDIR /app

ENV CI=true
ENV NODE_ENV=production

# Deps layer — cached unless lockfile changes.
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json ./
COPY apps/web/package.json apps/web/package.json
RUN pnpm install --frozen-lockfile

# Source (node_modules excluded via .dockerignore — see below).
COPY . .
RUN pnpm --filter @ddcons/web build

EXPOSE 3000
CMD ["pnpm", "--filter", "@ddcons/web", "start"]
