# --- dd-cons-shell env ---
# Generate the secret with: openssl rand -hex 32
SHELL_BETTER_AUTH_SECRET=replace-me-with-at-least-32-hex-chars

# Public base URL the shell serves from.
# Production: https://dd-cons.aroma-cloud.online
# Local dev:  http://localhost:3000
SHELL_BETTER_AUTH_URL=http://localhost:3000

# Cookie domain. Production should be ".dd-cons.aroma-cloud.online" so the
# session cookie is readable by dev-division + consulting-agency sub-paths.
# Leave unset in dev to let better-auth default to host-only on localhost.
SHELL_COOKIE_DOMAIN=

# GitHub OAuth (https://github.com/settings/developers)
SHELL_GITHUB_CLIENT_ID=
SHELL_GITHUB_CLIENT_SECRET=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
SHELL_GOOGLE_CLIENT_ID=
SHELL_GOOGLE_CLIENT_SECRET=
